# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=backstage
POSTGRES_PASSWORD=backstage

# Microsoft Entra ID (Azure AD)
AUTH_MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AUTH_MICROSOFT_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AUTH_MICROSOFT_CLIENT_SECRET=your-client-secret

# Azure DevOps
AZURE_DEVOPS_TOKEN=your-pat-token
AZURE_DEVOPS_ORG=your-org-name

# SonarQube (optional)
SONARQUBE_URL=https://sonarqube.example.com
SONARQUBE_TOKEN=your-sonarqube-token
